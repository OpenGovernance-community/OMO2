{"time":"2026-05-09T05:12:45+02:00","query":"SELECT\n\t\t\t\t\th.id,\n\t\t\t\t\th.name,\n\t\t\t\t\th.templatename,\n\t\t\t\t\th.IDtypeholon,\n\t\t\t\t\th.datemodification,\n\t\t\t\t\tMAX((CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(h.name, ''), COALESCE(h.templatename, ''))) = :structure_name_0_exact THEN 90 WHEN LOWER(CONCAT_WS(' ', COALESCE(h.name, ''), COALESCE(h.templatename, ''))) LIKE :structure_name_0_prefix THEN 55 WHEN LOWER(CONCAT_WS(' ', COALESCE(h.name, ''), COALESCE(h.templatename, ''))) LIKE :structure_name_0_like THEN 28 ELSE 0 END)) AS name_score,\n\t\t\t\t\tSUM(((CASE WHEN LOWER(COALESCE(p.name, '')) = :structure_property_name_0_exact THEN 26 WHEN LOWER(COALESCE(p.name, '')) LIKE :structure_property_name_0_prefix THEN 16 WHEN LOWER(COALESCE(p.name, '')) LIKE :structure_property_name_0_like THEN 10 ELSE 0 END) + (CASE WHEN LOWER(COALESCE(hp.value, '')) = :structure_property_value_0_exact THEN 18 WHEN LOWER(COALESCE(hp.value, '')) LIKE :structure_property_value_0_prefix THEN 10 WHEN LOWER(COALESCE(hp.value, '')) LIKE :structure_property_value_0_like THEN 6 ELSE 0 END))) AS property_score,\n\t\t\t\t\tMAX(\n\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\tWHEN ((CASE WHEN LOWER(COALESCE(p.name, '')) = :structure_property_name_0_exact THEN 26 WHEN LOWER(COALESCE(p.name, '')) LIKE :structure_property_name_0_prefix THEN 16 WHEN LOWER(COALESCE(p.name, '')) LIKE :structure_property_name_0_like THEN 10 ELSE 0 END) + (CASE WHEN LOWER(COALESCE(hp.value, '')) = :structure_property_value_0_exact THEN 18 WHEN LOWER(COALESCE(hp.value, '')) LIKE :structure_property_value_0_prefix THEN 10 WHEN LOWER(COALESCE(hp.value, '')) LIKE :structure_property_value_0_like THEN 6 ELSE 0 END)) > 0 THEN CONCAT(\n\t\t\t\t\t\t\t\tCOALESCE(p.name, ''),\n\t\t\t\t\t\t\t\tCASE WHEN TRIM(COALESCE(hp.value, '')) <> '' THEN ': ' ELSE '' END,\n\t\t\t\t\t\t\t\tLEFT(COALESCE(hp.value, ''), 180)\n\t\t\t\t\t\t\t)\n\t\t\t\t\t\t\tELSE ''\n\t\t\t\t\t\tEND\n\t\t\t\t\t) AS matched_excerpt\n\t\t\t\tFROM holon h\n\t\t\t\tL