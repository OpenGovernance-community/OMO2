{"time":"2026-05-09T05:23:08+02:00","query":"WITH RECURSIVE StructureNodes AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\th.id,\n\t\t\t\t\t\th.name,\n\t\t\t\t\t\th.templatename,\n\t\t\t\t\t\th.IDtypeholon,\n\t\t\t\t\t\th.datemodification,\n\t\t\t\t\t\th.IDholon_template\n\t\t\t\t\tFROM holon h\n\t\t\t\t\tWHERE h.IDholon_org = :root_holon_id\n\t\t\t\t\t  AND h.active = 1\n\t\t\t\t\t  AND h.visible = 1\n\t\t\t\t\t  AND h.IDtypeholon IN (1, 2, 3)\n\t\t\t\t),\n\t\t\t\tTemplateLineage AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\tsn.id AS holon_id,\n\t\t\t\t\t\tsn.id AS source_holon_id,\n\t\t\t\t\t\t0 AS depth\n\t\t\t\t\tFROM StructureNodes sn\n\n\t\t\t\t\tUNION ALL\n\n\t\t\t\t\tSELECT\n\t\t\t\t\t\ttl.holon_id,\n\t\t\t\t\t\tparent.IDholon_template AS source_holon_id,\n\t\t\t\t\t\ttl.depth + 1 AS depth\n\t\t\t\t\tFROM TemplateLineage tl\n\t\t\t\t\tINNER JOIN holon parent\n\t\t\t\t\t\tON parent.id = tl.source_holon_id\n\t\t\t\t\tWHERE parent.IDholon_template IS NOT NULL\n\t\t\t\t\t  AND parent.IDholon_template > 0\n\t\t\t\t),\n\t\t\t\tRankedDefinitions AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\ttl.holon_id,\n\t\t\t\t\t\thp.id,\n\t\t\t\t\t\thp.IDholon,\n\t\t\t\t\t\thp.IDproperty,\n\t\t\t\t\t\thp.value,\n\t\t\t\t\t\thp.position,\n\t\t\t\t\t\thp.mandatory,\n\t\t\t\t\t\thp.locked,\n\t\t\t\t\t\thp.active,\n\t\t\t\t\t\ttl.depth,\n\t\t\t\t\t\tROW_NUMBER() OVER (\n\t\t\t\t\t\t\tPARTITION BY tl.holon_id, hp.IDproperty\n\t\t\t\t\t\t\tORDER BY tl.depth ASC, hp.id DESC\n\t\t\t\t\t\t) AS definition_rank\n\t\t\t\t\tFROM TemplateLineage tl\n\t\t\t\t\tINNER JOIN holonproperty hp\n\t\t\t\t\t\tON hp.IDholon = tl.source_holon_id\n\t\t\t\t),\n\t\t\t\tPropertyLocks AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\trd.holon_id,\n\t\t\t\t\t\trd.IDproperty,\n\t\t\t\t\t\tMIN(CASE WHEN rd.active = 1 AND rd.locked = 1 THEN rd.depth ELSE NULL END) AS locked_depth\n\t\t\t\t\tFROM RankedDefinitions rd\n\t\t\t\t\tGROUP BY rd.holon_id, rd.IDproperty\n\t\t\t\t),\n\t\t\t\tEffectiveProperties AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\trd.holon_id,\n\t\t\t\t\t\tp.id AS IDproperty,\n\t\t\t\t\t\tMAX(p.name) AS property_name,\n\t\t\t\t\t\tMAX(p.shortname) AS property_shortname,\n\t\t\t\t\t\tMAX(\n\t\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\t\tWHEN rd.depth = 0\n\t\t\t\t\t\t\t\t\tAND rd.active = 1\n\t\t\t\t\t\t\t\t\tAND (pl.locked_depth IS NULL OR pl.locked_depth = 0)\n\t\t\t\t\t\t\t\tTHEN rd.value\n\t\t\t\t\t\t\t\tELSE NULL\n\t\t\t\t\t\t\tEND\n\t\t\t\t\t\t) AS value,\n\t\t\t\t\t\tGROUP_CONCAT(\n\t\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\t\tWHEN rd.depth > 0\n\t\t\t\t\t\t\t\t\tAND rd.active = 1\n\t\t\t\t\t\t\t\t\tAND rd.value IS NOT NULL\n\t\t\t\t\t\t\t\t\tAND TRIM(rd.value) <> ''\n\t\t\t\t\t\t\t\t\tAND (pl.locked_depth IS NULL OR rd.depth >= pl.locked_depth)\n\t\t\t\t\t\t\t\tTHEN rd.value\n\t\t\t\t\t\t\t\tELSE NULL\n\t\t\t\t\t\t\tEND\n\t\t\t\t\t\t\tORDER BY rd.depth ASC SEPARATOR ' | '\n\t\t\t\t\t\t) AS value_parents\n\t\t\t\t\tFROM RankedDefinitions rd\n\t\t\t\t\tINNER JOIN property p\n\t\t\t\t\t\tON p.id = rd.IDproperty\n\t\t\t\t\tLEFT JOIN PropertyLocks pl\n\t\t\t\t\t\tON pl.holon_id = rd.holon_id\n\t\t\t\t\t\tAND pl.IDproperty = rd.IDproperty\n\t\t\t\t\tWHERE EXISTS (\n\t\t\t\t\t\tSELECT 1\n\t\t\t\t\t\tFROM RankedDefinitions nearest\n\t\t\t\t\t\tWHERE nearest.holon_id = rd.holon_id\n\t\t\t\t\t\t  AND nearest.IDproperty = rd.IDproperty\n\t\t\t\t\t\t  AND nearest.definition_rank = 1\n\t\t\t\t\t\t  AND nearest.active = 1\n\t\t\t\t\t)\n\t\t\t\t\tGROUP BY rd.holon_id, p.id\n\t\t\t\t)\n\t\t\t\tSELECT\n\t\t\t\t\tsn.id,\n\t\t\t\t\tsn.name,\n\t\t\t\t\tsn.templatename,\n\t\t\t\t\tsn.IDtypeholon,\n\t\t\t\t\tsn.datemodification,\n\t\t\t\t\tMAX((CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(sn.name, ''), COALESCE(sn.templatename, ''))) = :structure_name_0_exact THEN 90 WHEN LOWER(CONCAT_WS(' ', COALESCE(sn.name, ''), COALESCE(sn.templatename, ''))) LIKE :structure_name_0_prefix THEN 55 WHEN LOWER(CONCAT_WS(' ', COALESCE(sn.name, ''), COALESCE(sn.templatename, ''))) LIKE :structure_name_0_like THEN 28 ELSE 0 END)) AS name_score,\n\t\t\t\t\tCOALESCE(SUM(((C