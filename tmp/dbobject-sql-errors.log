{"time":"2026-05-09T05:22:26+02:00","query":"WITH RECURSIVE StructureNodes AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\th.id,\n\t\t\t\t\t\th.name,\n\t\t\t\t\t\th.templatename,\n\t\t\t\t\t\th.IDtypeholon,\n\t\t\t\t\t\th.datemodification,\n\t\t\t\t\t\th.IDholon_template\n\t\t\t\t\tFROM holon h\n\t\t\t\t\tWHERE h.IDholon_org = :root_holon_id\n\t\t\t\t\t  AND h.active = 1\n\t\t\t\t\t  AND h.visible = 1\n\t\t\t\t\t  AND h.IDtypeholon IN (1, 2, 3)\n\t\t\t\t),\n\t\t\t\tTemplateLineage AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\tsn.id AS holon_id,\n\t\t\t\t\t\tsn.id AS source_holon_id,\n\t\t\t\t\t\t0 AS depth\n\t\t\t\t\tFROM StructureNodes sn\n\n\t\t\t\t\tUNION ALL\n\n\t\t\t\t\tSELECT\n\t\t\t\t\t\ttl.holon_id,\n\t\t\t\t\t\tparent.IDholon_template AS source_holon_id,\n\t\t\t\t\t\ttl.depth + 1 AS depth\n\t\t\t\t\tFROM TemplateLineage tl\n\t\t\t\t\tINNER JOIN holon parent\n\t\t\t\t\t\tON parent.id = tl.source_holon_id\n\t\t\t\t\tWHERE parent.IDholon_template IS NOT NULL\n\t\t\t\t\t  AND parent.IDholon_template > 0\n\t\t\t\t),\n\t\t\t\tRankedDefinitions AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\ttl.holon_id,\n\t\t\t\t\t\thp.id,\n\t\t\t\t\t\thp.IDholon,\n\t\t\t\t\t\thp.IDproperty,\n\t\t\t\t\t\thp.value,\n\t\t\t\t\t\thp.position,\n\t\t\t\t\t\thp.mandatory,\n\t\t\t\t\t\thp.locked,\n\t\t\t\t\t\thp.active,\n\t\t\t\t\t\ttl.depth,\n\t\t\t\t\t\tROW_NUMBER() OVER (\n\t\t\t\t\t\t\tPARTITION BY tl.holon_id, hp.IDproperty\n\t\t\t\t\t\t\tORDER BY tl.depth ASC, hp.id DESC\n\t\t\t\t\t\t) AS definition_rank\n\t\t\t\t\tFROM TemplateLineage tl\n\t\t\t\t\tINNER JOIN holonproperty hp\n\t\t\t\t\t\tON hp.IDholon = tl.source_holon_id\n\t\t\t\t),\n\t\t\t\tPropertyLocks AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\trd.holon_id,\n\t\t\t\t\t\trd.IDproperty,\n\t\t\t\t\t\tMIN(CASE WHEN rd.active = 1 AND rd.locked = 1 THEN rd.depth ELSE NULL END) AS locked_depth\n\t\t\t\t\tFROM RankedDefinitions rd\n\t\t\t\t\tGROUP BY rd.holon_id, rd.IDproperty\n\t\t\t\t),\n\t\t\t\tEffectiveProperties AS (\n\t\t\t\t\tSELECT\n\t\t\t\t\t\trd.holon_id,\n\t\t\t\t\t\tp.id AS IDproperty,\n\t\t\t\t\t\tMAX(p.name) AS property_name,\n\t\t\t\t\t\tMAX(p.shortname) AS property_shortname,\n\t\t\t\t\t\tMAX(\n\t\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\t\tWHEN rd.depth = 0\n\t\t\t\t\t\t\t\t\tAND rd.active = 1\n\t\t\t\t\t\t\t\t\tAND (pl.locked_depth IS NULL OR pl.locked_depth = 0)\n\t\t\t\t\t\t\t\tTHEN rd.value\n\t\t\t\t\t\t\t\tELSE NULL\n\t\t\t\t\t\t\tEND\n\t\t\t\t\t\t) AS value,\n\t\t\t\t\t\tGROUP_CONCAT(\n\t\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\t\tWHEN rd.depth > 0\n\t\t\t\t\t\t\t\t\tAND rd.active = 1\n\t\t\t\t\t\t\t\t\tAND rd.value IS NOT NULL\n\t\t\t\t\t\t\t\t\tAND TRIM(rd.value) <> ''\n\t\t\t\t\t\t\t\t\tAND (pl.locked_depth IS NULL OR rd.depth >= pl.locked_depth)\n\t\t\t\t\t\t\t\tTHEN rd.value\n\t\t\t\t\t\t\t\tELSE NULL\n\t\t\t\t\t\t\tEND\n\t\t\t\t\t\t\tORDER BY rd.depth ASC SEPARATOR ' | '\n\t\t\t\t\t\t) AS value_parents\n\t\t\t\t\tFROM RankedDefinitions rd\n\t\t\t\t\tINNER JOIN property p\n\t\t\t\t\t\tON p.id = rd.IDproperty\n\t\t\t\t\tLEFT JOIN PropertyLocks pl\n\t\t\t\t\t\tON pl.holon_id = rd.holon_id\n\t\t\t\t\t\tAND pl.IDproperty = rd.IDproperty\n\t\t\t\t\tWHERE EXISTS (\n\t\t\t\t\t\tSELECT 1\n\t\t\t\t\t\tFROM RankedDefinitions nearest\n\t\t\t\t\t\tWHERE nearest.holon_id = rd.holon_id\n\t\t\t\t\t\t  AND nearest.IDproperty = rd.IDproperty\n\t\t\t\t\t\t  AND nearest.definition_rank = 1\n\t\t\t\t\t\t  AND nearest.active = 1\n\t\t\t\t\t)\n\t\t\t\t\tGROUP BY rd.holon_id, p.id\n\t\t\t\t)\n\t\t\t\tSELECT\n\t\t\t\t\tsn.id,\n\t\t\t\t\tsn.name,\n\t\t\t\t\tsn.templatename,\n\t\t\t\t\tsn.IDtypeholon,\n\t\t\t\t\tsn.datemodification,\n\t\t\t\t\tMAX((CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(sn.name, ''), COALESCE(sn.templatename, ''))) = :structure_name_0_exact THEN 90 WHEN LOWER(CONCAT_WS(' ', COALESCE(sn.name, ''), COALESCE(sn.templatename, ''))) LIKE :structure_name_0_prefix THEN 55 WHEN LOWER(CONCAT_WS(' ', COALESCE(sn.name, ''), COALESCE(sn.templatename, ''))) LIKE :structure_name_0_like THEN 28 ELSE 0 END)) AS name_score,\n\t\t\t\t\tCOALESCE(SUM(((CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.property_name, ''), COALESCE(ep.property_shortname, ''))) = :structure_property_name_0_exact THEN 26 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.property_name, ''), COALESCE(ep.property_shortname, ''))) LIKE :structure_property_name_0_prefix THEN 16 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.property_name, ''), COALESCE(ep.property_shortname, ''))) LIKE :structure_property_name_0_like THEN 10 ELSE 0 END) + (CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.value, ''), COALESCE(ep.value_parents, ''))) = :structure_property_value_0_exact THEN 18 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.value, ''), COALESCE(ep.value_parents, ''))) LIKE :structure_property_value_0_prefix THEN 10 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.value, ''), COALESCE(ep.value_parents, ''))) LIKE :structure_property_value_0_like THEN 6 ELSE 0 END))), 0) AS property_score,\n\t\t\t\t\tMAX(\n\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\tWHEN ((CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.property_name, ''), COALESCE(ep.property_shortname, ''))) = :structure_property_name_0_exact THEN 26 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.property_name, ''), COALESCE(ep.property_shortname, ''))) LIKE :structure_property_name_0_prefix THEN 16 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.property_name, ''), COALESCE(ep.property_shortname, ''))) LIKE :structure_property_name_0_like THEN 10 ELSE 0 END) + (CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.value, ''), COALESCE(ep.value_parents, ''))) = :structure_property_value_0_exact THEN 18 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.value, ''), COALESCE(ep.value_parents, ''))) LIKE :structure_property_value_0_prefix THEN 10 WHEN LOWER(CONCAT_WS(' ', COALESCE(ep.value, ''), COALESCE(ep.value_parents, ''))) LIKE :structure_property_value_0_like THEN 6 ELSE 0 END)) > 0 THEN CONCAT(\n\t\t\t\t\t\t\t\tCOALESCE(ep.property_name, ''),\n\t\t\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\t\t\tWHEN TRIM(COALESCE(NULLIF(ep.value, ''), COALESCE(ep.value_parents, ''))) <> ''\n\t\t\t\t\t\t\t\t\tTHEN ': '\n\t\t\t\t\t\t\t\t\tELSE ''\n\t\t\t\t\t\t\t\tEND,\n\t\t\t\t\t\t\t\tLEFT(COALESCE(NULLIF(ep.value, ''), COALESCE(ep.value_parents, '')), 180)\n\t\t\t\t\t\t\t)\n\t\t\t\t\t\t\tELSE ''\n\t\t\t\t\t\tEND\n\t\t\t\t\t) AS matched_excerpt\n\t\t\t\tFROM StructureNodes sn\n\t\t\t\tLEFT JOIN EffectiveProperties ep\n\t\t\t\t\tON ep.holon_id = sn.id\n\t\t\t\tWHERE (LOWER(CONCAT_WS(' ', COALESCE(sn.name, ''), COALESCE(sn.templatename, ''))) LIKE :structure_prefilter_0_0 OR LOWER(CONCAT_WS(' ', COALESCE(ep.property_name, ''), COALESCE(ep.property_shortname, ''))) LIKE :structure_prefilter_1_0 OR LOWER(CONCAT_WS(' ', COALESCE(ep.value, ''), COALESCE(ep.value_parents, ''))) LIKE :structure_prefilter_2_0)\n\t\t\t\tGROUP BY sn.id, sn.name, sn.templatename, sn.IDtypeholon, sn.datemodification\n\t\t\t\tHAVING (name_score + property_score) > 0\n\t\t\t\tORDER BY (name_score + property_score) DESC, sn.datemodification DESC, sn.id DESC\n\t\t\t\tLIMIT 14","params":{"root_holon_id":904,"structure_name_0_exact":"support","structure_name_0_prefix":"support%","structure_name_0_like":"%support%","structure_property_name_0_exact":"support","structure_property_name_0_prefix":"support%","structure_property_name_0_like":"%support%","structure_property_value_0_exact":"support","structure_property_value_0_prefix":"support%","structure_property_value_0_like":"%support%","structure_prefilter_0_0":"%support%","structure_prefilter_1_0":"%support%","structure_prefilter_2_0":"%support%"},"message":"SQLSTATE[42S22]: Column not found: 1247 Reference 'name_score' not supported (reference to group function)","code":42,"request_uri":"/omo/api/search_popup.php?q=Support&oid=13&cid=912&scopes[]=__structure__","method":"GET","remote_addr":"172.19.0.1","script":"/omo/api/search_popup.php","database":"omodev","current_user":45,"current_organization":13}
