{"time":"2026-05-12T05:31:24+02:00","query":"SELECT\n\t\t\t\t\tu.id,\n\t\t\t\t\tu.firstname,\n\t\t\t\t\tu.lastname,\n\t\t\t\t\tCOALESCE(NULLIF(uo.username, ''), u.username, '') AS scoped_username,\n\t\t\t\t\tCOALESCE(NULLIF(uo.email, ''), u.email, '') AS scoped_email,\n\t\t\t\t\tMAX(uo.active) AS membership_active,\n\t\t\t\t\tMAX(uo.dateconnexion) AS membership_last_connection,\n\t\t\t\t\tMAX(uo.datecreation) AS membership_created_at,\n\t\t\t\t\tGROUP_CONCAT(\n\t\t\t\t\t\tDISTINCT NULLIF(\n\t\t\t\t\t\t\tCONCAT(\n\t\t\t\t\t\t\t\tCOALESCE(c_skill.name, ''),\n\t\t\t\t\t\t\t\tCASE\n\t\t\t\t\t\t\t\t\tWHEN TRIM(COALESCE(uc_skill.description, '')) <> '' THEN ': '\n\t\t\t\t\t\t\t\t\tELSE ''\n\t\t\t\t\t\t\t\tEND,\n\t\t\t\t\t\t\t\tCOALESCE(uc_skill.description, '')\n\t\t\t\t\t\t\t),\n\t\t\t\t\t\t\t''\n\t\t\t\t\t\t)\n\t\t\t\t\t\tSEPARATOR ' || '\n\t\t\t\t\t) AS competence_excerpt_source,\n\t\t\t\t\tCOALESCE(SUM((CASE WHEN LOWER(COALESCE(c_skill.name, '')) = :team_competence_name_0_exact THEN 54 WHEN LOWER(COALESCE(c_skill.name, '')) LIKE :team_competence_name_0_prefix THEN 32 WHEN LOWER(COALESCE(c_skill.name, '')) LIKE :team_competence_name_0_like THEN 16 ELSE 0 END) + (CASE WHEN LOWER(COALESCE(uc_skill.description, '')) = :team_competence_description_0_exact THEN 28 WHEN LOWER(COALESCE(uc_skill.description, '')) LIKE :team_competence_description_0_prefix THEN 16 WHEN LOWER(COALESCE(uc_skill.description, '')) LIKE :team_competence_description_0_like THEN 8 ELSE 0 END)), 0) AS competence_relevance,\n\t\t\t\t\t(\n\t\t\t\t\t\tMAX((CASE WHEN LOWER(CONCAT_WS(' ', COALESCE(u.firstname, ''), COALESCE(u.lastname, ''), COALESCE(NULLIF(uo.username, ''), u.username, ''), COALESCE(NULLIF(uo.email, ''), u.email, ''))) = :team_identity_0_exact THEN 80 WHEN LOWER(CONCAT_WS(' ', COALESCE(u.firstname, ''), COALESCE(u.lastname, ''), COALESCE(NULLIF(uo.username, ''), u.username, ''), COALESCE(NULLIF(uo.email, ''), u.email, ''))) LIKE :team_identity_0_prefix THEN 48 WHEN LOWER(CONCAT_WS(' ', COAL